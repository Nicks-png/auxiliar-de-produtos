# === Mercado Livre ===
# Opção 1: Token direto (expira em ~6h)
ML_ACCESS_TOKEN=

# Opção 2: App credentials (token renovado automaticamente)
# Crie seu app em: https://developers.mercadolivre.com.br/pt_br/aplicacoes-detalhe
ML_APP_ID=
ML_APP_SECRET=

# === Cache ===
CACHE_TTL_SECONDS=3600
CACHE_DIR=data
